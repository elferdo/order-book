{
  "db_name": "PostgreSQL",
  "query": "SELECT candidate.id, candidate.ask, candidate.bid, ask.price as ask_price, bid.price as bid_price,\nCOALESCE(approval.ask, FALSE) as approval_ask, COALESCE(approval.bid, FALSE) as approval_bid FROM candidate JOIN ask ON candidate.ask = ask.id JOIN bid ON candidate.bid = bid.id LEFT JOIN approval ON approval.candidate = candidate.id WHERE ask.user = $1 OR bid.user = $1",

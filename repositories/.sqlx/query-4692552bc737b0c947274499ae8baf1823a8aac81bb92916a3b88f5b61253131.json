  "query": "SELECT candidate.id, candidate.ask, candidate.bid, ask.price as ask_price, bid.price as bid_price, approval.ask as approval_ask, approval.bid as approval_bid FROM candidate JOIN ask ON candidate.ask = ask.id JOIN bid ON candidate.bid = bid.id JOIN approval ON approval.candidate = candidate.id WHERE ask.user = $1 OR bid.user = $1",
